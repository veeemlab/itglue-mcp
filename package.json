{
  "name": "@veeemlab/itglue-mcp",
  "version": "0.4.1",
  "description": "IT Glue MCP server with full read + write support (JSON:API, multi-region).",
  "type": "module",
  "bin": {
    "itglue-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "tsc || echo 'prepare: tsc skipped'",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsc --watch"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "itglue",
    "kaseya",
    "msp",
    "claude",
    "it-documentation"
  ],
  "author": "Vitalii Morgunov",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/veeemlab/itglue-mcp.git"
  },
  "homepage": "https://github.com/veeemlab/itglue-mcp#readme",
  "bugs": {
    "url": "https://github.com/veeemlab/itglue-mcp/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0"
  }
}
